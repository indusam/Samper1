<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <!-- Agrega el reporte al menú "imprimir" del modelo-->
        <record id="certificado_calidad_reporte" model="ir.actions.report">
            <field name="name">Certificado de Calidad</field>
            <field name="model">x_certificados_calidad</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">sam_reportes.certificado_calidad_template</field>
            <field name="report_file">sam_reportes.certificado_calidad_template</field>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Certificado de Calidad - %s' % (object.x_name or '')</field>
        </record>
    </data>
</odoo>