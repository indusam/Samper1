<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="formulas_costo_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div style="text-align:left;color:black!important;">
                        <div class="row">
                            <div class="col">
                                <table width="100%">
                                    <!-- Encabezado: sin ingrediente limitante -->
                                    <tr>
                                        <t t-if="cant_limitante == 0">
                                            <th class="table-active" colspan="8" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:14px;vertical-align:middle; padding:2px">
                                              <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                <span style="float: left; max-width: 80%; overflow: hidden; text-overflow: ellipsis;">
                                                  <strong>Fórmula con costeo:</strong> <span t-esc="codigo"/> - <span t-esc="producto"/>
                                                </span>
                                                <span style="float: right; white-space: nowrap; margin-left: 10px;">
                                                  <strong>Tipo de cambio: </strong><span t-esc="'{0:,.4f}'.format(env.company.x_studio_tipo_de_cambio or 0.0)"/>
                                                </span>
                                              </div>
                                              <div>
                                                <span><strong>Cantidad: </strong> <span t-esc="'{0:,.4f}'.format(masa_formula)"/> Kgs.</span>
                                                <t t-if="pct_merma > 0">
                                                  <span>&#160;&#160;<strong>% Merma: </strong><span t-esc="'{0:,.5f}'.format(pct_merma)"/>%&#160;&#160;
                                                    <strong>Kg. después de merma: </strong><span t-esc="'{0:,.4f}'.format(cantidad_despues_merma)"/>
                                                  </span>
                                                </t>
                                                <t t-if="bom_code">
                                                  <span>&#160;&#160;<span t-esc="bom_code"/></span>
                                                </t>
                                                <span style="float: right; white-space: nowrap; margin-left: 10px;">
                                                  <t t-if="tipo_costo">(<t t-esc="tipo_costo"/>)</t>
                                                </span>
                                              </div>
                                            </th>
                                        </t>
                                        <t t-if="cant_limitante > 0">
                                            <th class="table-active" colspan="8" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:14px;vertical-align:middle; padding:2px">
                                              <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                <span style="float: left; max-width: 80%; overflow: hidden; text-overflow: ellipsis;">
                                                  <strong>Fórmula: </strong> <span t-esc="codigo"/> - <span t-esc="producto"/>
                                                </span>
                                                <span style="float: right; white-space: nowrap; margin-left: 10px;">
                                                  <strong>Tipo de cambio: </strong><span t-esc="'{0:,.4f}'.format(env.company.x_studio_tipo_de_cambio or 0.0)"/>
                                                </span>
                                              </div>
                                              <div>
                                                <strong>Ingrediente limitante: </strong> <span t-esc="nombre_il"/>
                                                <br/>
                                                <strong>Cantidad: </strong> <span t-esc="'{0:,.4f}'.format(cant_limitante)"/> Kgs.
                                              </div>
                                            </th>
                                        </t>
                                    </tr>

                                    <!-- Encabezados de columnas -->
                                    <tr>
                                        <td class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>Ingrediente</strong>
                                        </td>
                                        <td class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>Código</strong>
                                        </td>
                                        <td class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>Cantidad</strong>
                                        </td>
                                        <td width="18" class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>Unidad</strong>
                                        </td>
                                        <td width="15" class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>$ USD</strong>
                                        </td>
                                        <td width="15" class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>$ MXN</strong>
                                        </td>
                                        <td width="15" class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>Importe MN</strong>
                                        </td>
                                        <td width="15" class="table-active" style="border-style: solid;border-width: 1px;border-top: 1px solid #000000;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:5px">
                                          <strong>% Costo</strong>
                                        </td>
                                    </tr>

                                    <!-- ── Precalcular totales ── -->
                                    <t t-set="total_cost_formula" t-value="0"/>
                                    <t t-foreach="vals" t-as="line">
                                        <t t-set="total_cost_formula" t-value="total_cost_formula + (line['costo'] * line['cant_comp'])"/>
                                    </t>

                                    <t t-set="total_cost_int_antes" t-value="0"/>
                                    <t t-foreach="intermedios_antes" t-as="item">
                                        <t t-set="total_cost_int_antes" t-value="total_cost_int_antes + (item.get('qty_needed', 0.0) * item.get('costo', 0.0))"/>
                                    </t>

                                    <t t-set="total_cost_int_despues" t-value="0"/>
                                    <t t-foreach="intermedios_despues" t-as="item">
                                        <t t-set="total_cost_int_despues" t-value="total_cost_int_despues + (item.get('qty_needed', 0.0) * item.get('costo', 0.0))"/>
                                    </t>

                                    <t t-set="combined_total" t-value="total_cost_formula + total_cost_int_antes + total_cost_int_despues"/>
                                    <t t-set="total_antes"    t-value="total_cost_formula + total_cost_int_antes"/>

                                    <!-- ── SECCIÓN: FÓRMULAS ── -->
                                    <t t-set="tot_gral_formula" t-value="0"/>
                                    <t t-foreach="vals" t-as="table_line">
                                        <tr>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                <t t-esc="table_line['componente']"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                <t t-esc="table_line['cod_prov']"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.4f}'.format(table_line['cant_comp'])"/>
                                                <t t-set="tot_gral_formula" t-value="tot_gral_formula + table_line['cant_comp']"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                <t t-esc="table_line['unidad']"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.4f}'.format(table_line['costo_usd'])"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.4f}'.format(table_line['costo'])"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.4f}'.format(table_line['costo'] * table_line['cant_comp'])"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.3f}'.format((table_line['costo'] * table_line['cant_comp'] / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                            </td>
                                        </tr>
                                    </t>

                                    <!-- Subtotal fórmulas -->
                                    <t t-set="costo_kg_formula" t-value="total_cost_formula / tot_gral_formula if tot_gral_formula > 0 else 0"/>
                                    <tr>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"><strong>Total Fórmulas</strong></td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"/>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong t-esc="'{0:,.4f}'.format(tot_gral_formula)"/>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"><strong>KG</strong></td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"/>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong t-esc="'{0:,.4f}'.format(costo_kg_formula)"/>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong t-esc="'{0:,.4f}'.format(total_cost_formula)"/>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <t t-esc="'{0:,.3f}'.format((total_cost_formula / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                        </td>
                                    </tr>

                                    <!-- ── SECCIÓN: INT. Y EMP. ANTES DE MERMA ── -->
                                    <t t-if="intermedios_antes">
                                        <tr>
                                            <td colspan="8" class="table-active" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:2px">
                                                <strong>Int. y Emp. Antes de Merma</strong>
                                            </td>
                                        </tr>
                                        <t t-foreach="intermedios_antes" t-as="item">
                                            <t t-set="item_qty"    t-value="item.get('qty_needed', 0.0)"/>
                                            <t t-set="item_costo"  t-value="item.get('costo', 0.0)"/>
                                            <t t-set="item_import" t-value="item_qty * item_costo"/>
                                            <tr>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                    <t t-esc="item.get('product_id', {}).get('name', '')"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"/>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item_qty)"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                    <t t-esc="item.get('product_uom_name', '')"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item.get('costo_usd', 0.0))"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item_costo)"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item_import)"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.3f}'.format((item_import / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                                </td>
                                            </tr>
                                        </t>
                                        <!-- Subtotal int. antes -->
                                        <t t-set="costo_kg_int_antes" t-value="total_cost_int_antes / masa_formula if masa_formula > 0 else 0"/>
                                        <tr>
                                            <td class="table-secondary" colspan="5" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <strong>Costo por Kg. de masa (int. antes):</strong>
                                            </td>
                                            <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <strong t-esc="'{0:,.4f}'.format(costo_kg_int_antes)"/>
                                            </td>
                                            <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <strong t-esc="'{0:,.4f}'.format(total_cost_int_antes)"/>
                                            </td>
                                            <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.3f}'.format((total_cost_int_antes / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                            </td>
                                        </tr>
                                    </t>

                                    <!-- ── TOTAL ANTES DE MERMA ── -->
                                    <t t-set="costo_kg_antes_merma" t-value="total_antes / masa_formula if masa_formula > 0 else 0"/>
                                    <tr>
                                        <td class="table-secondary" colspan="5" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong>Costo por Kg. de prod. antes de merma:</strong>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong t-esc="'{0:,.4f}'.format(costo_kg_antes_merma)"/>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong t-esc="'{0:,.4f}'.format(total_antes)"/>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <t t-esc="'{0:,.3f}'.format((total_antes / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                        </td>
                                    </tr>

                                    <!-- ── MERMA ── -->
                                    <t t-if="pct_merma > 0">
                                        <t t-set="costo_kg_post_merma" t-value="total_antes / cantidad_despues_merma if cantidad_despues_merma > 0 else 0"/>
                                        <tr>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                <strong>MERMA <t t-esc="'{0:,.5f}'.format(pct_merma)"/>%</strong>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"/>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.4f}'.format(cantidad_despues_merma)"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                KG
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"/>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.4f}'.format(costo_kg_post_merma)"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.4f}'.format(total_antes)"/>
                                            </td>
                                            <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.3f}'.format((total_antes / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                            </td>
                                        </tr>
                                    </t>

                                    <!-- ── SECCIÓN: INT. Y EMP. DESPUES DE MERMA ── -->
                                    <t t-if="intermedios_despues">
                                        <tr>
                                            <td colspan="8" class="table-active" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:12px;vertical-align:middle; padding:2px">
                                                <strong t-if="pct_merma > 0">Int. y Emp. Después de Merma</strong>
                                                <strong t-else="">Intermedios y Empaques</strong>
                                            </td>
                                        </tr>
                                        <t t-foreach="intermedios_despues" t-as="item">
                                            <t t-set="item_qty"    t-value="item.get('qty_needed', 0.0)"/>
                                            <t t-set="item_costo"  t-value="item.get('costo', 0.0)"/>
                                            <t t-set="item_import" t-value="item_qty * item_costo"/>
                                            <tr>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                    <t t-esc="item.get('product_id', {}).get('name', '')"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px"/>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item_qty)"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px">
                                                    <t t-esc="item.get('product_uom_name', '')"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item.get('costo_usd', 0.0))"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item_costo)"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.4f}'.format(item_import)"/>
                                                </td>
                                                <td style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                    <t t-esc="'{0:,.3f}'.format((item_import / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                                </td>
                                            </tr>
                                        </t>
                                        <!-- Subtotal int. después -->
                                        <t t-set="base_despues"         t-value="cantidad_despues_merma if cantidad_despues_merma > 0 else masa_formula"/>
                                        <t t-set="costo_kg_int_despues" t-value="total_cost_int_despues / base_despues if base_despues > 0 else 0"/>
                                        <tr>
                                            <td class="table-secondary" colspan="5" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <strong>Costo por Kg. de masa (int. después):</strong>
                                            </td>
                                            <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <strong t-esc="'{0:,.4f}'.format(costo_kg_int_despues)"/>
                                            </td>
                                            <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <strong t-esc="'{0:,.4f}'.format(total_cost_int_despues)"/>
                                            </td>
                                            <td class="table-secondary" style="border-style: solid;border-width: 1px;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                                <t t-esc="'{0:,.3f}'.format((total_cost_int_despues / combined_total) * 100 if combined_total > 0 else 0)"/>%
                                            </td>
                                        </tr>
                                    </t>

                                    <!-- ── COSTO FINAL POR KG DE PRODUCTO ── -->
                                    <t t-set="base_final"      t-value="cantidad_despues_merma if cantidad_despues_merma > 0 else masa_formula"/>
                                    <t t-set="costo_final_kg"  t-value="combined_total / base_final if base_final > 0 else 0"/>
                                    <tr>
                                        <td class="table-secondary" colspan="5" style="border-style: solid;border-width: 1px;border-top: 2px solid #000000;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong>Costo final por Kg. de producto:</strong>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;border-top: 2px solid #000000;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong t-esc="'{0:,.4f}'.format(costo_final_kg)"/>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;border-top: 2px solid #000000;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong t-esc="'{0:,.4f}'.format(combined_total)"/>
                                        </td>
                                        <td class="table-secondary" style="border-style: solid;border-width: 1px;border-top: 2px solid #000000;padding-bottom:0px;padding-top:0px;font-size:11px;vertical-align:middle; padding:2px" align="right">
                                            <strong>100.000%</strong>
                                        </td>
                                    </tr>

                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
    <record id="paperformat_custom_tabla_nutrimental_report" model="report.paperformat">
        <field name="name">Tabla Nutrimental Report</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">45</field>
        <field name="dpi">90</field>
    </record>
</odoo>
