<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="wizard_editar_notas_move_form" model="ir.ui.view">
    <field name="name">wizard.editar.notas.move.form</field>
    <field name="model">wizard.editar.notas.move</field>
    <field name="arch" type="xml">
      <form string="Editar Notas">
        <group>
          <field name="move_id" readonly="1"/>
          <field name="x_notas"/>
        </group>
        <footer>
          <button name="action_guardar" type="object" string="Guardar" class="btn-primary"/>
          <button string="Cancelar" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
